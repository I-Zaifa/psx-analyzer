# Keep build inputs (freeze.py, app/, backend/, data/csv) available for Vercel.
# Only ignore caches, logs, and non-deploy metadata.

# Python cache artefacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Local virtual environments
.venv/

# Generated build output (should not be committed)
build/

# Runtime cache/logs not needed for static builds
data/cache/
data/logs/

# Non-deploy metadata
.github/
netlify.toml
README.md
